{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@portfolinho/db": ["../../packages/db/src/index.ts"],
      "@portfolinho/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
