# ═══════════════════════════════════════════════════════════════════════════
# Portfolinho — Miljövariabler
# Kopiera denna fil till .env och fyll i värdena
# ═══════════════════════════════════════════════════════════════════════════

# ── Publik URL ──────────────────────────────────────────────────────────────
# Den URL som institutionens användare och Canvas når Portfolinho på.
# Måste matcha exakt med det du registrerar i Canvas Developer Key.
PUBLIC_URL=https://portfolinho.ditt-larosate.se

# Porten som docker-compose exponerar (vad som är utåt på värddatorn)
PORT=3000

# ── Databas ─────────────────────────────────────────────────────────────────
# Lösenord för den interna PostgreSQL-instansen
DB_PASSWORD=byt-ut-detta-till-ett-starkt-losenord

# ── Fillagring (MinIO) ───────────────────────────────────────────────────────
MINIO_USER=portfolinho
MINIO_PASSWORD=byt-ut-detta-till-ett-starkt-losenord

# ── Autentisering (Better Auth) ──────────────────────────────────────────────
# Genereras automatiskt av install.sh — en lång slumpmässig sträng
BETTER_AUTH_SECRET=

# ── LTI 1.3 ─────────────────────────────────────────────────────────────────
# Fylls i efter att du registrerat Portfolinho i Canvas (steg 3 i INSTALL.md)
#
# LTI_KEY_ID:      Unikt ID för ditt nyckelpar (t.ex. portfolinho-hv-2025)
# LTI_PRIVATE_KEY: RSA-privat nyckel i PEM-format (genereras av install.sh)
# CANVAS_ISSUER:   Din Canvas-instans, t.ex. https://canvas.hv.se

LTI_KEY_ID=
LTI_PRIVATE_KEY=
CANVAS_ISSUER=

# ── Canvas REST API (OAuth2) ─────────────────────────────────────────────────
# Krävs för synk av lärandemål och rubriker (steg 4 i INSTALL.md)
# Hämtas från Canvas → Admin → Developer Keys
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=
